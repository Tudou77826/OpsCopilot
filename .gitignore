```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.tsbuildinfo

# Environment variables
.env
.env.local
*.env.*

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Temporary files
*.tmp

# Coverage reports
coverage/
htmlcov/
*.coverage

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
.env/

# MyPy cache
.mypy_cache/

# Pytest cache
.pytest_cache/

# Distribution / packaging
.Python
*.egg-info/
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Compression
*.zip
*.tar.gz
*.tar.bz2
*.tar.xz
*.gz
*.rar
*.7z
*.bz2
*.xz
*.Z
*.lz
*.lzo
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
```