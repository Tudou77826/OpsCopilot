    "examples": ["ssh user@host", "ssh -p 2222 user@host", "ssh -i ~/.ssh/key.pem user@host"]
  },
  {
    "name": "scp",
    "description": "通过 SSH 安全复制文件",
    "category": "network",
    "options": [
