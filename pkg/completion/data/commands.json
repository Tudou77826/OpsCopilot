      { "flag": "--delete", "description": "删除目标中源没有的文件" },
      { "flag": "-e", "description": "指定远程 Shell", "requires_value": true }
    ],
    "examples": ["rsync -avz src/ dest/", "rsync -avz --progress dir/ user@host:/path/"]
  },
  {
    "name": "curl",
    "description": "传输数据到服务器或从服务器获取数据",
    "category": "network",
    "options": [
      { "flag": "-O", "description": "保存到本地文件（使用远程文件名）" },
      { "flag": "-o", "description": "指定输出文件", "requires_value": true },
