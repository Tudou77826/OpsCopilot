      { "flag": "-p", "description": "保留文件属性" },
      { "flag": "-P", "description": "指定端口", "requires_value": true },
      { "flag": "-i", "description": "指定身份文件", "requires_value": true }
    ],
    "examples": ["scp file.txt user@host:/path/", "scp -r dir/ user@host:/path/"]
  },
  {
    "name": "rsync",
    "description": "远程同步工具",
    "category": "network",
    "options": [
