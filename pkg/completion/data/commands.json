    "examples": ["kill 1234", "kill -9 1234", "kill -l"]
  },
  {
    "name": "killall",
    "description": "按名称杀死进程",
    "category": "system",
    "options": [
      { "flag": "-9", "description": "强制杀死进程" },
      { "flag": "-i", "description": "杀死前询问确认" }
    ],
    "examples": ["killall nginx", "killall -9 firefox"]
  },
  {
    "name": "systemctl",
    "description": "控制系统和服务",
    "category": "system",
    "options": [
      { "flag": "start", "description": "启动服务" },
      { "flag": "stop", "description": "停止服务" },
      { "flag": "restart", "description": "重启服务" },
      { "flag": "status", "description": "查看服务状态" },
      { "flag": "enable", "description": "设置开机自启" },
      { "flag": "disable", "description": "取消开机自启" },
      { "flag": "reload", "description": "重新加载配置" },
      { "flag": "-l", "description": "列出所有服务" }
    ],
    "examples": ["systemctl start nginx", "systemctl status docker", "systemctl enable sshd"]
  },
  {
    "name": "service",
    "description": "运行 System V init 脚本",
    "category": "system",
    "options": [
      { "flag": "start", "description": "启动服务" },
      { "flag": "stop", "description": "停止服务" },
      { "flag": "restart", "description": "重启服务" },
      { "flag": "status", "description": "查看服务状态" }
    ],
    "examples": ["service nginx status", "service mysql restart"]
  },
  {
    "name": "uname",
    "description": "显示系统信息",
    "category": "system",
    "options": [
      { "flag": "-a", "description": "显示所有信息" },
      { "flag": "-r", "description": "显示内核版本" },
      { "flag": "-m", "description": "显示机器硬件" },
      { "flag": "-n", "description": "显示主机名" }
    ],
    "examples": ["uname -a", "uname -r"]
  },
  {
    "name": "df",
    "description": "显示磁盘空间使用情况",
    "category": "system",
    "options": [
      { "flag": "-h", "description": "人类可读格式" },
      { "flag": "-H", "description": "1000 而非 1024 为单位" },
      { "flag": "-i", "description": "显示 inode 使用情况" },
      { "flag": "-T", "description": "显示文件系统类型" }
    ],
    "examples": ["df -h", "df -i"]
  },
  {
    "name": "du",
    "description": "显示目录或文件的磁盘使用量",
    "category": "system",
    "options": [
      { "flag": "-h", "description": "人类可读格式" },
      { "flag": "-s", "description": "只显示总计" },
      { "flag": "-a", "description": "显示所有文件" },
      { "flag": "--max-depth", "description": "限制显示深度", "requires_value": true }
    ],
    "examples": ["du -sh *", "du -h --max-depth=1 /var"]
  },
  {
    "name": "free",
    "description": "显示内存使用情况",
    "category": "system",
    "options": [
      { "flag": "-h", "description": "人类可读格式" },
      { "flag": "-m", "description": "以 MB 为单位显示" },
      { "flag": "-g", "description": "以 GB 为单位显示" },
      { "flag": "-s", "description": "持续监控", "requires_value": true }
    ],
    "examples": ["free -h", "free -m"]
  },
  {
    "name": "uptime",
    "description": "显示系统运行时间和负载",
    "category": "system",
    "options": [],
    "examples": ["uptime"]
  },
  {
    "name": "ssh",
    "description": "安全 Shell 客户端",
    "category": "network",
    "options": [
      { "flag": "-i", "description": "指定身份文件（密钥）", "requires_value": true },
      { "flag": "-p", "description": "指定端口", "requires_value": true },
      { "flag": "-l", "description": "指定登录用户", "requires_value": true },
      { "flag": "-L", "description": "本地端口转发" },
      { "flag": "-R", "description": "远程端口转发" }
