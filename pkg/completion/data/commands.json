[
  {
    "name": "ls",
    "description": "列出目录内容",
    "category": "file",
    "combos": [
      { "text": "-la", "description": "长列表+包含隐藏文件（常用）" },
      { "text": "-lh", "description": "长列表+人类可读大小（常用）" },
      { "text": "-lAh", "description": "长列表+除 . .. 外的隐藏文件+人类可读（常用）" },
      { "text": "-ltr", "description": "按时间排序+反向（常用）" },
      { "text": "-lart", "description": "长列表+包含隐藏文件+按时间排序+反向（常用）" }
    ],
    "options": [
      { "flag": "-l", "description": "使用长格式显示详细信息" },
      { "flag": "-a", "description": "显示所有文件，包括以.开头的隐藏文件" },
      { "flag": "-h", "description": "人类可读的文件大小（如 1K, 234M, 2G）" },
      { "flag": "-t", "description": "按修改时间排序" },
      { "flag": "-r", "description": "反向排序" },
      { "flag": "-R", "description": "递归列出子目录" },
      { "flag": "--color", "description": "颜色化输出（always/never/auto）", "requires_value": true }
    ],
    "examples": ["ls -la", "ls -lh /var/log", "ls -t | head -10"],
    "aliases": ["dir"]
  },
  {
    "name": "cd",
    "description": "切换当前工作目录",
    "category": "file",
    "options": [
      { "flag": "-", "description": "返回上一个目录" },
      { "flag": "~", "description": "切换到用户主目录" }
    ],
    "examples": ["cd /var/log", "cd ~", "cd -"]
  },
  {
    "name": "pwd",
    "description": "显示当前工作目录的完整路径",
    "category": "file",
    "options": [
      { "flag": "-P", "description": "显示物理路径，不跟随符号链接" }
    ],
    "examples": ["pwd"]
  },
  {
    "name": "cp",
    "description": "复制文件或目录",
    "category": "file",
    "options": [
      { "flag": "-r", "description": "递归复制目录" },
      { "flag": "-i", "description": "覆盖前提示确认" },
      { "flag": "-v", "description": "显示复制过程" },
      { "flag": "-p", "description": "保留文件属性" },
      { "flag": "-a", "description": "归档模式，保留所有属性" }
    ],
    "examples": ["cp file1.txt file2.txt", "cp -r dir1 dir2", "cp -av src/ dst/"]
  },
  {
    "name": "mv",
    "description": "移动或重命名文件或目录",
    "category": "file",
    "options": [
      { "flag": "-i", "description": "覆盖前提示确认" },
      { "flag": "-v", "description": "显示移动过程" },
      { "flag": "-n", "description": "不覆盖已存在的文件" }
    ],
    "examples": ["mv old.txt new.txt", "mv file.txt /tmp/"]
  },
  {
    "name": "rm",
    "description": "删除文件或目录",
    "category": "file",
    "options": [
      { "flag": "-r", "description": "递归删除目录" },
      { "flag": "-f", "description": "强制删除，不提示确认" },
      { "flag": "-i", "description": "删除前提示确认" },
      { "flag": "-v", "description": "显示删除过程" }
    ],
    "examples": ["rm file.txt", "rm -rf directory/"]
  },
  {
    "name": "mkdir",
    "description": "创建目录",
    "category": "file",
    "options": [
      { "flag": "-p", "description": "递归创建父目录" },
      { "flag": "-v", "description": "显示创建过程" },
      { "flag": "-m", "description": "设置目录权限", "requires_value": true }
    ],
    "examples": ["mkdir newdir", "mkdir -p /path/to/nested/dir"]
  },
  {
    "name": "rmdir",
    "description": "删除空目录",
    "category": "file",
    "options": [
      { "flag": "-p", "description": "递归删除空父目录" }
    ],
    "examples": ["rmdir emptydir"]
  },
  {
    "name": "touch",
    "description": "创建空文件或更新文件时间戳",
    "category": "file",
    "options": [
      { "flag": "-a", "description": "只更新访问时间" },
      { "flag": "-m", "description": "只更新修改时间" },
      { "flag": "-c", "description": "不创建文件" },
      { "flag": "-d", "description": "设置指定时间", "requires_value": true }
    ],
    "examples": ["touch newfile.txt", "touch -d '2024-01-01' file.txt"]
  },
  {
    "name": "find",
    "description": "在目录树中搜索文件",
    "category": "file",
    "combos": [
      { "text": "-name \"*.log\"", "description": "按文件名匹配（常用）" },
      { "text": "-type f -name \"*.log\"", "description": "只找文件+按文件名匹配（常用）" },
      { "text": "-maxdepth 1 -type f", "description": "只在当前层查找文件（常用）" },
      { "text": "-type f -mtime +7", "description": "查找 7 天前修改的文件（常用）" }
    ],
    "options": [
      { "flag": "-name", "description": "按文件名搜索", "requires_value": true },
      { "flag": "-type", "description": "按文件类型搜索（f/d/l）", "requires_value": true },
      { "flag": "-size", "description": "按文件大小搜索", "requires_value": true },
      { "flag": "-mtime", "description": "按修改时间搜索（天）", "requires_value": true },
      { "flag": "-exec", "description": "对搜索结果执行命令", "requires_value": true }
    ],
    "examples": ["find / -name '*.log'", "find . -type f -mtime +7", "find . -size +100M"]
  },
  {
    "name": "locate",
    "description": "快速查找文件（使用数据库）",
    "category": "file",
    "options": [
      { "flag": "-i", "description": "忽略大小写" },
      { "flag": "-c", "description": "只显示匹配数量" }
    ],
    "examples": ["locate filename", "locate -i '*.conf'"]
  },
  {
    "name": "cat",
    "description": "连接文件并打印到标准输出",
    "category": "text",
    "options": [
      { "flag": "-n", "description": "显示行号" },
      { "flag": "-b", "description": "对非空行编号" },
      { "flag": "-s", "description": "压缩多个空行为一行" }
    ],
    "examples": ["cat file.txt", "cat -n file.txt", "cat file1.txt file2.txt"]
  },
  {
    "name": "less",
    "description": "分页显示文件内容（可向前翻页）",
    "category": "text",
    "options": [
      { "flag": "-N", "description": "显示行号" },
      { "flag": "+F", "description": "类似 tail -f 的效果" },
      { "flag": "-S", "description": "不换行长行" }
    ],
    "examples": ["less file.txt", "less +F /var/log/syslog"]
  },
  {
    "name": "more",
    "description": "分页显示文件内容",
    "category": "text",
    "options": [
      { "flag": "-n", "description": "指定每屏行数", "requires_value": true }
    ],
    "examples": ["more file.txt", "ls -l | more"]
  },
  {
    "name": "head",
    "description": "显示文件开头部分",
    "category": "text",
    "options": [
      { "flag": "-n", "description": "显示前 n 行", "requires_value": true },
      { "flag": "-c", "description": "显示前 n 字节", "requires_value": true }
    ],
    "examples": ["head file.txt", "head -n 20 file.txt"]
  },
  {
    "name": "tail",
    "description": "显示文件结尾部分",
    "category": "text",
    "combos": [
      { "text": "-f", "description": "实时跟踪新增内容（常用）" },
      { "text": "-n 200", "description": "显示最后 200 行（常用）" },
      { "text": "-n 200 -f", "description": "先看最后 200 行再跟踪（常用）" }
    ],
    "options": [
      { "flag": "-n", "description": "显示后 n 行", "requires_value": true },
      { "flag": "-f", "description": "实时跟踪文件新增内容" },
      { "flag": "-F", "description": "跟踪文件名（文件轮转时继续跟踪）" }
    ],
    "examples": ["tail -f /var/log/syslog", "tail -n 100 file.txt"]
  },
  {
    "name": "grep",
    "description": "在文件中搜索文本模式",
    "category": "text",
    "combos": [
      { "text": "-rni", "description": "递归+行号+忽略大小写（常用）" },
      { "text": "-rn", "description": "递归+行号（常用）" },
      { "text": "-in", "description": "忽略大小写+行号（常用）" },
      { "text": "-rniE", "description": "递归+行号+忽略大小写+扩展正则（常用）" }
    ],
    "options": [
      { "flag": "-i", "description": "忽略大小写" },
      { "flag": "-r", "description": "递归搜索目录" },
      { "flag": "-n", "description": "显示行号" },
      { "flag": "-v", "description": "反向匹配（显示不匹配的行）" },
      { "flag": "-c", "description": "只显示匹配行数" },
      { "flag": "--color", "description": "高亮显示匹配", "requires_value": true },
      { "flag": "-E", "description": "使用扩展正则表达式" }
    ],
    "examples": ["grep 'error' log.txt", "grep -r 'TODO' ./src", "ps aux | grep nginx"]
  },
  {
    "name": "sed",
    "description": "流编辑器，用于文本转换",
    "category": "text",
    "options": [
      { "flag": "-i", "description": "直接修改文件" },
      { "flag": "-n", "description": "禁止自动打印" },
      { "flag": "-e", "description": "执行脚本", "requires_value": true }
    ],
    "examples": ["sed 's/old/new/g' file.txt", "sed -i 's/foo/bar/g' *.txt"]
  },
  {
    "name": "awk",
    "description": "模式扫描和处理语言",
    "category": "text",
    "options": [
      { "flag": "-F", "description": "指定字段分隔符", "requires_value": true },
      { "flag": "-v", "description": "赋值变量", "requires_value": true }
    ],
    "examples": ["awk '{print $1}' file.txt", "awk -F: '{print $1}' /etc/passwd"]
  },
  {
    "name": "sort",
    "description": "对文本行进行排序",
    "category": "text",
    "options": [
      { "flag": "-r", "description": "反向排序" },
      { "flag": "-n", "description": "按数值排序" },
      { "flag": "-u", "description": "去重" },
      { "flag": "-k", "description": "指定排序字段", "requires_value": true },
      { "flag": "-t", "description": "指定字段分隔符", "requires_value": true }
    ],
    "examples": ["sort file.txt", "sort -nr numbers.txt", "sort -u names.txt"]
  },
  {
    "name": "uniq",
    "description": "报告或忽略重复的行",
    "category": "text",
    "options": [
      { "flag": "-c", "description": "显示重复次数" },
      { "flag": "-d", "description": "只显示重复行" },
      { "flag": "-u", "description": "只显示唯一行" },
      { "flag": "-i", "description": "忽略大小写" }
    ],
    "examples": ["sort file.txt | uniq -c", "uniq -d file.txt"]
  },
  {
    "name": "wc",
    "description": "统计文件的行数、字数、字节数",
    "category": "text",
    "options": [
      { "flag": "-l", "description": "只统计行数" },
      { "flag": "-w", "description": "只统计字数" },
      { "flag": "-c", "description": "只统计字节数" },
      { "flag": "-m", "description": "只统计字符数" }
    ],
    "examples": ["wc file.txt", "wc -l file.txt", "ls | wc -l"]
  },
  {
    "name": "ps",
    "description": "显示当前运行的进程",
    "category": "system",
    "options": [
      { "flag": "aux", "description": "显示所有用户的所有进程" },
      { "flag": "-ef", "description": "显示所有进程信息" },
      { "flag": "-e", "description": "显示所有进程" },
      { "flag": "-f", "description": "完整格式显示" },
      { "flag": "--forest", "description": "以树形结构显示" }
    ],
    "examples": ["ps aux", "ps -ef | grep nginx", "ps aux --forest"]
  },
  {
    "name": "top",
    "description": "实时显示系统进程和资源使用",
    "category": "system",
    "options": [],
    "examples": ["top"]
  },
  {
    "name": "htop",
    "description": "交互式进程查看器（top 的增强版）",
    "category": "system",
    "options": [],
    "examples": ["htop"]
  },
  {
    "name": "kill",
    "description": "向进程发送信号",
    "category": "system",
    "options": [
      { "flag": "-9", "description": "强制杀死进程（SIGKILL）" },
      { "flag": "-15", "description": "优雅终止进程（SIGTERM）" },
